set.seed(123)
bh_reject <- function(p, alpha = 0.1) {
m <- length(p)
ord <- order(p)
p_ord <- p[ord]
thresh <- alpha * (1:m) / m
k <- max(c(0, which(p_ord <= thresh)))
rej <- rep(FALSE, m)
if (k > 0) rej[ord[1:k]] <- TRUE
rej
}
cond_pvals_from_tilde <- function(p, tilde) {
out <- numeric(length(p))
out[tilde == 1] <- p[tilde == 1]^2
out[tilde == 0] <- 2 * p[tilde == 0] - p[tilde == 0]^2
out
}
simulate_one_dataset <- function(alpha = 0.1, group_size = 100, n_groups = 20,
n_signal_groups = 5, screen_thresh = 40) {
n <- group_size * n_groups
is_nonnull <- rep(FALSE, n)
signal_groups <- sample(n_groups, n_signal_groups, replace = FALSE)
p <- numeric(n)
group_id <- rep(1:n_groups, each = group_size)
for (g in 1:n_groups) {
idx <- which(group_id == g)
if (g %in% signal_groups) {
nn_idx_temp <- sample(group_size, 50, replace = FALSE)
nn_idx <- idx[nn_idx_temp]
null_idx <- setdiff(idx, nn_idx)
p[nn_idx] <- runif(50)^4
p[null_idx] <- runif(50)
is_nonnull[nn_idx] <- TRUE
} else {
p[idx] <- runif(group_size)
}
}
rej1 <- bh_reject(p, alpha = alpha)
R1 <- sum(rej1)
V1 <- sum(rej1 & !is_nonnull)
S1 <- sum(rej1 & is_nonnull)
m1 <- sum(is_nonnull)
fdr1 <- if (R1 == 0) 0 else V1 / R1
power1 <- if (m1 == 0) 0 else S1 / m1
tilde <- rbinom(n, size = 1, prob = p)
# Screen groups using only tilde
ones_per_group <- tapply(tilde, group_id, sum)
selected_groups <- which(ones_per_group <= screen_thresh)
selected <- group_id %in% selected_groups
# Compute conditional p-values for all, but test only selected subset
p_cond <- cond_pvals_from_tilde(p, tilde)
rej2 <- rep(FALSE, n)
if (any(selected)) {
rej2_sel <- bh_reject(p_cond[selected], alpha = alpha)
rej2[selected] <- rej2_sel
}
R2 <- sum(rej2)
V2 <- sum(rej2 & !is_nonnull)
S2 <- sum(rej2 & is_nonnull)
fdr2 <- if (R2 == 0) 0 else V2 / R2
power2 <- if (m1 == 0) 0 else S2 / m1
c(FDR_BH = fdr1, Power_BH = power1,
FDR_screen = fdr2, Power_screen = power2,
n_selected_groups = length(selected_groups))
}
# -----------------------------
# Monte Carlo experiment
# -----------------------------

set.seed(1)
B_keep <- 10000
batch  <- 1000
accepted_means <- numeric(0)
while (length(accepted_means) < B_keep) {
X <- matrix(rnorm(batch * 5), ncol = 5)
# selection event: at least one patient has improvement >= 1.5
sel <- apply(X, 1, max) >= 1.5
if (any(sel)) {
accepted_means <- c(accepted_means, rowMeans(X[sel, , drop = FALSE]))
}
}
accepted_means <- accepted_means[1:B_keep]
# Selective p-value for observed Xbar = 1
p_sel <- mean(accepted_means >= 1)
p_sel

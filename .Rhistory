Mean_FDR = c(mean(res[, "FDR_BH"]), mean(res[, "FDR_screen"])),
SD_FDR   = c(sd(res[, "FDR_BH"]),   sd(res[, "FDR_screen"])),
Mean_Power = c(mean(res[, "Power_BH"]), mean(res[, "Power_screen"])),
SD_Power   = c(sd(res[, "Power_BH"]),   sd(res[, "Power_screen"]))
)
